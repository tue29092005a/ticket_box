@baseUrl = http://localhost:3333
@token = YOUR_TOKEN_HERE
@eventId = YOUR_EVENT_ID_HERE

### 1. Register an Organizer
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "organizer@example.com",
  "password": "password123"
}

### 2. Login (Copy the access_token from the response into the @token variable above, or rely on REST Client auto-chaining if supported)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "organizer@example.com",
  "password": "password123"
}

### 3. Create Draft (Step 1 Initiation)
# @name createDraft
POST {{baseUrl}}/api/organizer/concerts
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk

### Note: Copy the event_id from the response above into the @eventId variable

### 4. Save Step 1 (Event Info)
PUT {{baseUrl}}/api/organizer/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3/step/1
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
Content-Type: application/json

{
  "name": "My Awesome Concert",
  "category": "Music",
  "address_type": "OFFLINE",
  "venue_name": "My Arena",
  "province": "Hanoi",
  "ward": "Dich Vong",
  "street": "123 Xuan Thuy",
  "organizer_name": "Super Organizer",
  "description": "The best concert ever"
}

### 5. Save Step 2 (Datetime & Tickets)
PUT {{baseUrl}}/api/organizer/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3/step/2
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
Content-Type: application/json

{
  "start_time": "2026-10-15T20:00:00Z",
  "ticket_types": [
    {
      "name": "VIP",
      "price": 1000000,
      "is_free": false,
      "total_quantity": 50,
      "min_per_order": 1,
      "max_per_order": 4
    },
    {
      "name": "GA",
      "price": 500000,
      "is_free": false,
      "total_quantity": 200,
      "min_per_order": 1,
      "max_per_order": 10
    }
  ]
}

### 6. Save Step 3 (Settings)
PUT {{baseUrl}}/api/organizer/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3/step/3
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
Content-Type: application/json

{
  "slug": "my-awesome-concert-2026",
  "privacy": "PUBLIC",
  "confirmation_message": "Thanks for buying! See you at the event."
}

### 7. Save Step 4 (Payment & Publish)
# THIS WILL PUBLISH THE EVENT
PUT {{baseUrl}}/api/organizer/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3/step/4
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
Content-Type: application/json

{
  "bank_account_name": "SUPER ORGANIZER",
  "bank_account_number": "123456789",
  "bank_name": "VCB",
  "vat_business_type": "INDIVIDUAL"
}

### 8. Get Draft Status
GET {{baseUrl}}/api/organizer/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3/draft
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk

### 9. List All Events (Public)
GET {{baseUrl}}/api/concerts?page=1&limit=10

### 10. Get Public Event Detail
GET {{baseUrl}}/api/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3

### 11. Admin: Update Event
PUT {{baseUrl}}/api/admin/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
Content-Type: application/json

{
  "description": "Updated concert description!"
}

### 12. Admin: Cancel Event
DELETE {{baseUrl}}/api/admin/concerts/6f71fefb-3fe1-49db-9fb2-a316d66846f3
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkNzMwMWZmMS0zMzEzLTQ4Y2YtYWIyMy00ZTE2MTlhZWNlMzkiLCJpYXQiOjE3ODMwOTA5NzUsImV4cCI6MTc4MzA5MTg3NX0.-zH6I_xZBucSzqbTsJEkXd9cMQa0NI-XHWJwwqCezGk
