# Database Config (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ticketbox

# Redis Config (Centralized Cache & Distributed Lock)
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Config (Message Broker for asynchronous queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# MeiliSearch Config (Full-text search for Events/Artists)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKey

# JWT Secret (Authentication)
JWT_SECRET=super-secret-key
JWT_EXPIRATION=3600s

# ─── MinIO Object Storage ─────────────────────────────────────────────────────
# Root credentials (used only server-side — NEVER sent to browser)
MINIO_ROOT_USER=ticketbox_admin
MINIO_ROOT_PASSWORD=ticketbox_secret_2026

# Internal endpoint (Docker network — used by NestJS S3Client)
MINIO_ENDPOINT=http://localhost:9000

# Public endpoint (reachable by browser — used in presigned URLs)
# When routing through Nginx: set to http://localhost:3000/minio
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Bucket names
MINIO_BUCKET_IMAGES=ticketbox-images
MINIO_BUCKET_CSV=ticketbox-csv-imports

# Presigned URL TTL (seconds)
MINIO_PRESIGN_TTL_IMAGES=900       # 15 min — image uploads (≤5 MB)
MINIO_PRESIGN_TTL_CSV=3600         # 1 hour  — CSV uploads  (≤500 MB)

# Max allowed object sizes (bytes)
MINIO_MAX_SIZE_IMAGES=5242880      # 5 MB
MINIO_MAX_SIZE_CSV=524288000       # 500 MB
