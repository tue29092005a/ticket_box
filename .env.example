# Database Config (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=ticketbox
DB_PASSWORD=password
DB_NAME=ticketbox_db

# Redis Config (Centralized Cache & Distributed Lock)
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Config (Message Broker for asynchronous queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# MeiliSearch Config (Full-text search for Events/Artists)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKey

# MongoDB Config
MONGO_URI=mongodb://admin:password@localhost:27017/ticketbox_db?authSource=admin

# JWT Secret (Authentication)
JWT_SECRET=super-secret-key
JWT_EXPIRATION=3600s

# PayPal Sandbox (https://developer.paypal.com)
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_SECRET=YOUR_SANDBOX_SECRET
PAYPAL_WEBHOOK_ID=YOUR_WEBHOOK_ID
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_MODE=sandbox

# SMTP (Nodemailer — Recommend Gmail App Password for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=TicketBox <noreply@ticketbox.vn>

# VND to USD Exchange Rate (for PayPal Sandbox demo)
VND_TO_USD_RATE=25000
