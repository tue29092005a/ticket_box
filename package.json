{
  "name": "ticket-box",
  "version": "1.0.0",
  "description": "TicketBox - Hybrid Caching and Background Processing System",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "ts-node src/main.ts",
    "start:auth": "cross-env PORT=3001 SERVICE_NAME=auth ts-node src/main.ts",
    "start:booking": "cross-env PORT=3002 SERVICE_NAME=booking ts-node src/main.ts",
    "start:info": "cross-env PORT=3003 SERVICE_NAME=info ts-node src/main.ts",
    "start:worker": "ts-node src/apps-worker/processors/order.processor.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/typeorm": "^10.0.0",
    "amqplib": "^0.10.3",
    "bcrypt": "^6.0.0",
    "csv-parser": "^3.0.0",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.38.0",
    "mongoose": "^9.6.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
