    "@nestjs/testing": "^10.4.22",
    "@types/amqplib": "^0.10.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/k6": "^0.49.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.14",
